# Contract Deployment Configuration

# Private key for deployment (must be funded with ETH for gas)
PRIVATE_KEY=0x...

# RPC URL for target network
# 0G Testnet: https://evmrpc-testnet.0g.ai
# Ethereum Sepolia: https://sepolia.infura.io/v3/YOUR_INFURA_KEY
# Base Sepolia: https://sepolia.base.org
RPC_URL=https://evmrpc-testnet.0g.ai

# Network name (optional, for logging)
NETWORK=0G Testnet

# Etherscan API key (optional, for verification)
# ETHERSCAN_API_KEY=...
